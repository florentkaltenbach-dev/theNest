# scripts/setup/systemd/nest-energyhack-app.service
#
# Serves the EnergyHackPrep Streamlit app (the EH autocoder's output) on the wg0
# mesh at 10.0.0.3:8501, so Kaltenbach's nginx can reverse-proxy it out as
# https://energyhack.kaltenbach.dev over IPv4. Runs from an isolated detached
# worktree (/opt/energyhack-live @ build tip) so the EH executor's branch
# switching in /opt/energyhack never disrupts the live app. Uses the project venv.
[Unit]
Description=EnergyHackPrep Streamlit app (energyhack.kaltenbach.dev)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=claude
Group=claude
WorkingDirectory=/opt/energyhack-live
Environment=HOME=/home/claude
ExecStart=/opt/energyhack/.venv/bin/streamlit run app.py \
  --server.address 10.0.0.3 --server.port 8501 --server.headless true \
  --browser.gatherUsageStats false --server.enableCORS false \
  --server.enableXsrfProtection false
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
