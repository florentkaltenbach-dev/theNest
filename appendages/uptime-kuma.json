{
  "name": "uptime-kuma",
  "version": "1.0.0",
  "description": "Self-hosted monitoring tool",
  "category": "tooling",
  "requirements": {
    "min_ram_mb": 128,
    "min_cpu_cores": 0.25
  },
  "container": {
    "image": "louislam/uptime-kuma:1",
    "ports": ["3001:3001"],
    "volumes": ["uptime-kuma-data:/app/data"]
  },
  "routes": [
    { "path": "/uptime", "port": 3001 }
  ]
}
