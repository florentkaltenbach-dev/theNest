{
  "name": "gitea",
  "version": "1.0.0",
  "description": "Lightweight self-hosted Git service",
  "category": "tooling",
  "requirements": {
    "min_ram_mb": 256,
    "min_cpu_cores": 0.5
  },
  "container": {
    "image": "gitea/gitea:latest",
    "ports": ["3002:3000"],
    "volumes": ["gitea-data:/data"]
  },
  "routes": [
    { "path": "/git", "port": 3002 }
  ]
}
