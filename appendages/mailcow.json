{
  "name": "mailcow",
  "version": "0.1.0",
  "description": "Self-hosted Mailcow stack on stoneshop.de host. Brownfield adoption — already running, status observed via SSH against the mailcowdockerized-* container set.",
  "category": "service",
  "discovery": {
    "host": "stoneshop",
    "containers": {
      "match_any": [
        "^mailcowdockerized-postfix-mailcow-1$",
        "^mailcowdockerized-dovecot-mailcow-1$",
        "^mailcowdockerized-mysql-mailcow-1$",
        "^mailcowdockerized-redis-mailcow-1$",
        "^mailcowdockerized-nginx-mailcow-1$",
        "^mailcowdockerized-rspamd-mailcow-1$",
        "^mailcowdockerized-sogo-mailcow-1$"
      ]
    }
  }
}
