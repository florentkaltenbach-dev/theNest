# ── theNest Configuration ──────────────────────────────
# Copy to config.env and fill in values. NEVER commit config.env.

# ── Claude Code Auth ──────────────────────────────────
# "apikey" = use ANTHROPIC_API_KEY below
# "oauth"  = run 'claude login' on server (interactive)
CLAUDE_AUTH_MODE=apikey
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI Codex Auth ─────────────────────────────────
# "apikey" = use OPENAI_API_KEY below
# "oauth"  = Codex CLI OAuth (uses ChatGPT subscription)
CODEX_AUTH_MODE=oauth
OPENAI_API_KEY=sk-...

# ── Repo Access ───────────────────────────────────────
# "deploykey" = SSH deploy key (generated by wizard, stored in .deploy-key)
# "token"     = GitHub personal access token
REPO_AUTH_MODE=deploykey
GITHUB_TOKEN=

# ── Server ─────────────────────────────────────────────
# Path to your SSH private key (on your local machine)
SSH_KEY_PATH=~/.ssh/id_ed25519_hetzner

# ── Git Identity ───────────────────────────────────────
# Used for commits. Defaults to "nest" / "nest@hostname" if empty.
GIT_USER_NAME=
GIT_USER_EMAIL=

# ── Repo ───────────────────────────────────────────────
NEST_REPO=https://github.com/florentkaltenbach-dev/theNest.git
NEST_BRANCH=main

# ── Token ledger caps (C10) ────────────────────────────
# Optional. Leave unset to surface used tokens with "remaining unknown".
# Reset day = day of month the OAuth subscription resets (UTC).
NEST_CAP_CODEX_PRO_TOKENS=
NEST_CAP_CODEX_PRO_RESET_DAY=1
NEST_CAP_CLAUDE_PRO_TOKENS=
NEST_CAP_CLAUDE_PRO_RESET_DAY=1
# Optional. If set, openrouter-promo source pulls /api/v1/credits.
OPENROUTER_API_KEY=

# ── Outbound SMTP (kaltenbach mailcow relay) ───────────
# Mailbox provisioned via mailcow API. Used by hub/src/mail.js.
SMTP_HOST=mail.kaltenbach.dev
SMTP_PORT=587
SMTP_USER=nest@kaltenbach.dev
SMTP_PASS=
SMTP_FROM="Nest Hub <nest@kaltenbach.dev>"

# ── Alerting ────────────────────────────────────────────
# Comma-separated mail recipients for alert watchdog (host offline, appendage
# unhealthy, etc.). Defaults to ausfragezeichen@gmail.com if unset.
ALERT_RECIPIENTS=
# Threshold + tick override (defaults: 180s offline, 60s tick).
NEST_HOST_OFFLINE_THRESHOLD_MS=
NEST_ALERT_TICK_MS=
